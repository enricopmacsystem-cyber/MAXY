{
  "name": "Maxy - Review parallela (GitHub)",
  "description": "Due automazioni separate consigliate: code-review + security su push o PR.",
  "workflow": {
    "triggers": [
      {
        "type": "github_push_to_branch",
        "repository": "enricopmacsystem-cyber/MAXY",
        "branch": "main",
        "comment": "Cursor UI: GitHub -> Push to branch -> main. Alternativa: Pull request opened"
      }
    ],
    "automations": [
      {
        "name": "Maxy - Code review on push",
        "model": "claude-sonnet",
        "memoryEnabled": false,
        "promptFile": ".cursor/automations/prompts/code-review-on-push.md"
      },
      {
        "name": "Maxy - Security on push",
        "model": "claude-opus",
        "memoryEnabled": false,
        "promptFile": ".cursor/automations/prompts/security-on-push.md"
      }
    ],
    "gitConfig": {
      "repository": "enricopmacsystem-cyber/MAXY",
      "branch": "main"
    }
  }
}
