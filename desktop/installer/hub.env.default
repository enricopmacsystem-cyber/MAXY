# Configurazione servizio locale MAC AI Assistant
# Modificare solo se PostgreSQL usa credenziali diverse

AUTH_REQUIRED=true
AI_ASSISTANT_NAME=Maxy
APP_CURRENT_VERSION=2.0
DATABASE_URL=postgresql+psycopg2://postgres:admin@localhost:5432/tech_assistant

EASYONE_MODE=hybrid
EASYONE_AUTH_MODE=http
EASYONE_PORTAL_URL=https://e.macsystem.online
EASYONE_CRM_URL=https://e.macsystem.online
EASYONE_BASE_URL=https://e.macsystem.online/_api/easyone.crmapi/api
EASYONE_API_URL=https://e.macsystem.online/_api/easyone.crmapi/api
EASYONE_EVENTS_URL=https://e.macsystem.online/_api/events/api
EASYONE_TENANT_ID=5a70023f-7e07-4e78-9346-b18f90dda7ee
EASYONE_TIMEOUT_SECONDS=20

ERP_BASE_URL=https://e.macsystem.online/_api/easyone.crmapi/api

# Maxy AI — Google Gemini (quota gratuita: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Posta — OAuth Gmail / Outlook (redirect da registrare nei portali cloud)
# Gmail: https://console.cloud.google.com/apis/credentials
# Outlook: https://portal.azure.com/ → App registrations
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/mail/oauth/callback

# EasyOne agenda (se diverso dall'endpoint predefinito)
EASYONE_PATH_CALENDAR_EVENTS=/calendar/events

# Maxy — modalità Supporto tecnico (bot manuali Mac System, ChromaDB + Claude)
ANTHROPIC_API_KEY=
CHROMA_DIR=C:\macsystem\chroma_db
DOCUMENTS_NETWORK_MANUAL_PATH=\\172.17.17.11\collegamenti\Manuale tecnico
DOCUMENTS_NETWORK_DATASHEET_PATH=\\172.17.17.11\collegamenti\Datasheet
MACSYSTEM_LOCAL_MANUAL_PATH=C:\macsystem\manuali
