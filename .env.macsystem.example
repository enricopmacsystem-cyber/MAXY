# =============================================================================
# MAC AI Assistant — EasyOne CRM MAC SYSTEM
# Copiare in .env e completare OPENAI_API_KEY + EASYONE_TENANT_ID
# Riferimento: docs/EASYONE_MACSYSTEM_API.md
# =============================================================================

OPENAI_API_KEY=sk-your-key-here

AUTH_REQUIRED=true
AI_ASSISTANT_NAME=Maxy
APP_CURRENT_VERSION=1.0.0
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tech_assistant

# --- URL EasyOne (Bot Ticket / documentazione interna) ---
EASYONE_MODE=hybrid
EASYONE_AUTH_MODE=http
EASYONE_CRM_URL=https://e.macsystem.online
EASYONE_API_URL=https://e.macsystem.online/_api/easyone.crmapi/api
EASYONE_EVENTS_URL=https://e.macsystem.online/_api/events/api
EASYONE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EASYONE_NEUTRAL_CUSTOMER_ID=
EASYONE_TIMEOUT_SECONDS=20

ERP_BASE_URL=https://e.macsystem.online/_api/easyone.crmapi/api

# Login: POST {EASYONE_API_URL}/authentication/Login
# Body: username, password, tenantId, loginType=0
EASYONE_PATH_AUTH_LOGIN=/authentication/Login
EASYONE_PATH_CUSTOMERS_SEARCH=/people
EASYONE_PATH_TICKETS_BY_EVENT=/tickets/{event_id}
EASYONE_PATH_EVENTS_CREATE=/Event
EASYONE_PATH_EVENTS_BASIC_INFO=/event/GetEventBasicInfo/{app_id}
